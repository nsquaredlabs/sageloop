# Supabase - Get these from your Supabase project dashboard (Project Settings → API)
# For local development: http://127.0.0.1:54321
# For production: https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Publishable Key (formerly "anon key") - safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-publishable-key
# Secret Key (formerly "service_role key") - NEVER expose in browser, server-only
SUPABASE_SERVICE_ROLE_KEY=your-supabase-secret-key

# Site URL - Used for OAuth redirect URLs
# For local development: http://localhost:3000
# For production: https://workbench.sageloop.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI - Get from https://platform.openai.com/api-keys
# Optional: Used as fallback when users don't provide their own keys
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic - Get from https://console.anthropic.com/settings/keys
# Required when SYSTEM_MODEL_CONFIG uses Anthropic models (for extractions, insights)
# Optional: Used as fallback when users don't provide their own keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ============================================================================
# OAuth Authentication (Google & GitHub)
# ============================================================================
# OAuth configuration is done in the Supabase Dashboard, NOT via environment variables.
#
# Setup Steps:
# 1. Go to Supabase Dashboard → Authentication → Providers
# 2. Enable Google and/or GitHub providers
# 3. Configure OAuth credentials (see below)
#
# Google OAuth Setup:
# 1. Go to Google Cloud Console → APIs & Services → Credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add authorized redirect URI: https://your-project-ref.supabase.co/auth/v1/callback
# 4. Copy Client ID and Client Secret to Supabase Dashboard
#
# GitHub OAuth Setup:
# 1. Go to GitHub → Settings → Developer Settings → OAuth Apps
# 2. Create a new OAuth App
# 3. Set Homepage URL to your app URL (e.g., https://workbench.sageloop.app)
# 4. Set Authorization callback URL: https://your-project-ref.supabase.co/auth/v1/callback
# 5. Copy Client ID and Client Secret to Supabase Dashboard
#
# Supabase Dashboard Configuration:
# - Allowed redirect URLs (for production):
#   - https://workbench.sageloop.app/auth/callback
# - Allowed redirect URLs (for development):
#   - http://localhost:3000/auth/callback
# ============================================================================
