# OpenAI - Get from https://platform.openai.com/api-keys
# Used for generating AI outputs with OpenAI models (GPT-4, GPT-5, etc.)
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic - Get from https://console.anthropic.com/settings/keys
# Used for generating AI outputs with Claude models
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Note: API keys can also be configured via the Settings UI at /settings/api-keys
# They are stored locally in sageloop.config.yaml and never leave your machine.
